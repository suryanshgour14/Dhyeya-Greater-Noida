# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-sanity-api-token

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# EmailJS (client-side enquiry form only)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your-emailjs-service-id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your-emailjs-template-id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your-emailjs-public-key

# Owner purchase-notification email (server-side, free via Gmail SMTP)
# GMAIL_APP_PASSWORD = a Google "App Password" (Account > Security > App passwords),
# NOT your normal Gmail password. Requires 2-Step Verification enabled.
GMAIL_USER=youraccount@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
OWNER_EMAIL=owner@dhyeyagreaternoida.com   # who receives purchase alerts (comma-separated ok)

# Cron secret — protects /api/payments/reconcile (Vercel Cron sends this automatically)
CRON_SECRET=any-long-random-string

# Site
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
